<?xml version='1.0' standalone='yes'?>
<!DOCTYPE PLUGIN>

<PLUGIN 
  name="unraid-newenckey-preview"
  author="@doron"
  version="2026.03.10"
  launch="Settings"
  pluginURL="https://raw.githubusercontent.com/doron1/unraid-newenckey/main/plugin/unraid-newenckey-preview.plg"
  support="https://forums.unraid.net/topic/85495-unraid-newenckey-change-your-drive-encryption-unlock-key/"
  min="6.7.0"
  
  icon="fa-key"
>

<CHANGES>
<![CDATA[

### 2026.03.10

- Create a UI wrapper around the script, in the Unraid admin UI under Settings


For older releases, see https://github.com/doron1/unraid-newenckey/releases
]]>
</CHANGES>

<FILE Name="/boot/config/plugins/unraid-newenckey/unraid-newenckey-2026.03.10-noarch-1.txz">
<URL>https://github.com/doron1/unraid-newenckey/releases/download/2026.03.10/unraid-newenckey-2026.03.10-noarch-1.txz</URL>
<SHA256>c34bef68c3953460c669f3899c874263e86f38e8331c8127a280f5bdcfd59f70</SHA256>
</FILE>

<!--
The 'install' script.
-->
<FILE Run="/bin/bash">
<INLINE>
<![CDATA[
upgradepkg --install-new /boot/config/plugins/unraid-newenckey/unraid-newenckey-2026.03.10-noarch-1.txz

# cleanup old versions
rm -f $(ls /boot/config/plugins/unraid-newenckey/unraid-newenckey-*.txz 2>/dev/null | grep -v '2026.03.10')

echo ""
echo "----------------------------------------------------"
echo " unraid-newenckey has been installed."
echo " Version: 2026.03.10"
echo "----------------------------------------------------"
echo ""
]]>
</INLINE>
</FILE>

<!--
The 'remove' script.
-->
<FILE Run="/bin/bash" Method="remove">
<INLINE>
<![CDATA[
removepkg unraid-newenckey

rm -rf /usr/local/emhttp/plugins/unraid-newenckey
#rm -rf /boot/config/plugins/unraid-newenckey
]]>
</INLINE>
</FILE>

</PLUGIN>
